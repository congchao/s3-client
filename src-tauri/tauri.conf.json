{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "S3 Client",
  "version": "1.0.0",
  "identifier": "com.mironizz.s3-client",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 720,
        "center": true,
        "transparent": false,
        "dragDropEnabled":  true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/icon_16x16.png",
      "icons/icon_16x16@2x.png",
      "icons/icon_32x32.png",
      "icons/icon_32x32@2x.png",
      "icons/icon_128x128.png",
      "icons/icon_128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0MUVDQkZEQTI1N0MyN0MKUldSOHdsZWkvY3NlaEgwbDZKNi9SaHZMbVhKeWMxaDYwTWFjSnpkeGY3V3FrRWRuejVLb2Q2Q1YK",
      "endpoints": [
        "https://github.com/congchao/s3-client/releases/latest/download/latest.json"
      ]
    }
  }
}
